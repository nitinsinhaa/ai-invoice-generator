NODE_ENV=development
PORT=5000

DB_HOST=localhost
DB_PORT=5432
DB_NAME=ai_invoice_db
DB_USER=postgres
DB_PASSWORD=your_password

# Required: at least 16 characters in production
JWT_SECRET=your_jwt_secret_key_minimum_16_chars
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

FRONTEND_URL=http://localhost:3000

GEMINI_API_KEY=your_gemini_api_key_here

# SMTP (Nodemailer) — use Gmail App Password, not your normal password
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_gmail_app_password_16_chars
EMAIL_FROM=AI Invoice Generator <your_email@gmail.com>

UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=500
